# ── Copy this file to ".env.local" and fill in the values ──

# The password you'll type on the site to unlock editing.
# Pick something long that only you know. Everyone else can still VIEW
# without any password.
EDIT_PASSWORD=change-me-to-a-long-secret

# Secret used to sign the login cookie. Generate any long random string, e.g.
# run:  openssl rand -base64 33     (or use https://generate-secret.vercel.app)
AUTH_SECRET=

# Neon Postgres connection string (from the Neon dashboard — see README).
DATABASE_URL=
