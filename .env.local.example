# ── Copy this file to ".env.local" and fill in the values ──

# Clerk (handles sign-in / sign-up). Get both keys from the Clerk dashboard
# → API keys. See README.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Where the sign-in / sign-up pages live (leave these as-is).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# The two sign-up codes you hand out. Pick anything you like.
# Give EMPLOYEE_CODE to employees, BOSS_CODE to bosses.
EMPLOYEE_CODE=
BOSS_CODE=

# Neon Postgres connection string (from Neon / Vercel — see README).
DATABASE_URL=
